    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// After Merge (Combine by Position),\n// you will have ONLY ONE item\n\nconst resume_data = items[0].json;\nconst jd_data = items[1].json;\n\n// Adjust these field names based on your Extract node output\nconst resumeText = resume_data.text || resume_data.resumeText || \"\";\nconst jdText = jd_data.text || jd_data.jdText || \"\";\n\n\n// Get email from Webhook\nconst candidateEmail =\n  $node[\"Resume Upload Trigger\"].json.body?.candidateEmail || \"\";\n\nreturn [\n  {\n    json: {\n      resumeText,\n      jdText,\n      candidateEmail\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        496,
        -32
      ],
      "id": "79ba5700-afb5-4979-a374-6db66ebf180e",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output;\n\nconst cleaned = raw\n  .replace(/```json/g, \"\");\n // .replace(/```/g, \"\")\n // .trim();\n\nconst parsed = JSON.parse(cleaned);\n\nreturn [{ json: parsed}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
